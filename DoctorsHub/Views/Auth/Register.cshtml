@model RegisterDto

@{
    Layout = null;
    ViewData["Title"] = "Create Account";
}

<link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">


<div class="auth-page">

    <div class="auth-container">


        <!-- ===========================
             Left Branding Section
        ============================ -->

        <div class="auth-brand-section">

            <div class="auth-brand">

                <div class="auth-brand-logo">
                    <i class="bi bi-heart-pulse-fill"></i>
                </div>


                <div class="auth-brand-text">

                    <h1>
                        DoctorsHub
                    </h1>

                    <p>
                        MultiSpeciality Hospital Management System
                    </p>

                </div>

            </div>


            <ul class="auth-feature-list">


                <li>
                    <i class="bi bi-check-circle-fill"></i>
                    Manage Doctors & Specializations
                </li>


                <li>
                    <i class="bi bi-check-circle-fill"></i>
                    Appointment Scheduling
                </li>


                <li>
                    <i class="bi bi-check-circle-fill"></i>
                    Patient Management
                </li>


                <li>
                    <i class="bi bi-check-circle-fill"></i>
                    CRM Dashboard
                </li>


                <li>
                    <i class="bi bi-check-circle-fill"></i>
                    Business Insights & Analytics
                </li>


            </ul>


        </div>



        <!-- ===========================
             Register Form
        ============================ -->


        <div class="auth-form-section">


            <div class="auth-form-wrapper">


                <h2>
                    Create Account
                </h2>


                <p class="auth-form-subtitle">
                    Create your DoctorsHub account to get started.
                </p>



                <form asp-action="Register" method="post">


                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>



                    <!-- Name -->

                    <div class="auth-name-grid">


                        <div class="auth-form-group">


                            <label asp-for="FirstName"
                                   class="auth-form-label">
                            </label>


                            <input asp-for="FirstName"
                                   class="auth-form-control"
                                   placeholder="First Name" />


                            <span asp-validation-for="FirstName"
                                  class="text-danger">
                            </span>


                        </div>



                        <div class="auth-form-group">


                            <label asp-for="LastName"
                                   class="auth-form-label">
                            </label>


                            <input asp-for="LastName"
                                   class="auth-form-control"
                                   placeholder="Last Name" />


                            <span asp-validation-for="LastName"
                                  class="text-danger">
                            </span>


                        </div>


                    </div>





                    <!-- Email -->


                    <div class="auth-form-group">


                        <label asp-for="Email"
                               class="auth-form-label">
                        </label>


                        <input asp-for="Email"
                               class="auth-form-control"
                               placeholder="Enter your email" />


                        <span asp-validation-for="Email"
                              class="text-danger">
                        </span>


                    </div>






                    <!-- Password -->


                    <div class="auth-form-group">


                        <label asp-for="Password"
                               class="auth-form-label">
                        </label>



                        <div class="auth-password-wrapper">


                            <input asp-for="Password"
                                   type="password"
                                   id="password"
                                   class="auth-form-control"
                                   placeholder="Enter password" />


                        </div>


                        <span asp-validation-for="Password"
                              class="text-danger">
                        </span>


                    </div>






                    <!-- Confirm Password -->


                    <div class="auth-form-group">


                        <label asp-for="ConfirmPassword"
                               class="auth-form-label">
                        </label>



                        <div class="auth-password-wrapper">


                            <input asp-for="ConfirmPassword"
                                   type="password"
                                   id="confirmPassword"
                                   class="auth-form-control"
                                   placeholder="Confirm password" />


                        </div>


                        <span asp-validation-for="ConfirmPassword"
                              class="text-danger">
                        </span>


                    </div>





                    <button type="submit"
                            class="auth-btn">


                        Create Account


                    </button>




                </form>





                <div class="auth-footer">


                    Already have an account?


                    <a asp-action="Login">
                        Sign In
                    </a>


                </div>



            </div>


        </div>



    </div>


</div>




@section Scripts {

    <partial name="_ValidationScriptsPartial" />


    <script>

        function togglePassword(id, element) {

            const input = document.getElementById(id);

            const icon = element.querySelector("i");


            if (input.type === "password") {

                input.type = "text";

                icon.classList.remove("bi-eye");

                icon.classList.add("bi-eye-slash");

            }
            else {

                input.type = "password";

                icon.classList.remove("bi-eye-slash");

                icon.classList.add("bi-eye");

            }

        }


    </script>

}
<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - DoctorHub</title>

    <!-- Google Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

</head>

<body>

    <div class="app-layout">

        <!-- ================= Sidebar ================= -->

        <aside class="sidebar" id="sidebar">

            <!-- Brand -->

            <div class="brand">

                <div class="brand-logo">

                    <i class="bi bi-heart-pulse-fill"></i>

                </div>

                <div class="brand-text">

                    <h2>DoctorHub</h2>

                    <span>Enterprise Healthcare</span>

                </div>

            </div>

            <!-- Navigation -->

            <nav class="sidebar-nav">

                <ul>

                    <li>

                        <a asp-controller="DashBoard"
                           asp-action="Index"
                           class="active">

                            <i class="bi bi-grid"></i>

                            <span>Dashboard</span>

                        </a>

                    </li>

                    <li>

                        <a asp-controller="Doctor"
                           asp-action="Index">

                            <i class="bi bi-person-badge"></i>

                            <span>Doctors</span>

                        </a>

                    </li>

                    <li>

                        <a asp-controller="Patients"
                        asp-action="Index">

                            <i class="bi bi-people"></i>

                            <span>Patients</span>

                        </a>

                    </li>

                    <li>

                        <a asp-controller="Appointments" 
                        asp-action="Index">

                            <i class="bi bi-calendar-check"></i>

                            <span>Appointments</span>

                        </a>

                    </li>

                    <li>

                        <a href="#">

                            <i class="bi bi-building"></i>

                            <span>Departments</span>

                        </a>

                    </li>

                    <li>

                        <a href="#">

                            <i class="bi bi-credit-card"></i>

                            <span>Billing</span>

                        </a>

                    </li>

                    <li>

                        <a href="#">

                            <i class="bi bi-bar-chart-line"></i>

                            <span>Reports</span>

                        </a>

                    </li>

                </ul>

            </nav>

            <!-- Sidebar Footer -->

            <div class="sidebar-footer">

                <a href="#">

                    <i class="bi bi-gear"></i>

                    <span>Settings</span>

                </a>

            </div>

        </aside>

        <!-- ================= Main ================= -->

        <main class="main-content">

            <!-- ================= Topbar ================= -->

            <header class="topbar">

                <div class="topbar-left">

                    <button id="sidebarToggle" class="menu-btn">

                        <i class="bi bi-list"></i>

                    </button>

                    <div class="page-title">

                        <h3>@ViewData["Title"]</h3>

                        <small>DoctorHub Enterprise Healthcare</small>

                    </div>

                </div>

                <div class="topbar-right">

                    <!-- Search -->

                    <div class="search-box">

                        <i class="bi bi-search"></i>

                        <input type="text"
                               placeholder="Search..." />

                    </div>

                    <!-- Notification -->

                    <button class="icon-btn">

                        <i class="bi bi-bell"></i>

                    </button>

                    <!-- User -->

                    <div class="user-profile">

                        <div class="avatar">

                            A

                        </div>

                        <div class="user-info">

                            <strong>Administrator</strong>

                            <small>System Admin</small>

                        </div>

                    </div>

                </div>

            </header>

            <!-- ================= Page Content ================= -->

            <section class="page-content">

                @RenderBody()

            </section>

        </main>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        const sidebar = document.getElementById("sidebar");
        const btn = document.getElementById("sidebarToggle");

        btn.addEventListener("click", () => {

        sidebar.classList.toggle("collapsed");

        localStorage.setItem(
        "sidebar",
        sidebar.classList.contains("collapsed")
        );

        });

        if(localStorage.getItem("sidebar") === "true"){

        sidebar.classList.add("collapsed");

        }

    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
@model PagedResult<BillDto>

@{
    ViewData["Title"] = "Billing";
}

<div class="page-container">

    <!-- Header -->
    <div class="header">
        <h2>Billing</h2>
    </div>

    <!-- Search & Filter -->
    <form method="get" class="filter-bar">

        <select name="searchBy">

            <option value="BillId" selected="@(Context.Request.Query["searchBy"] == "BillId")">
                Bill ID
            </option>

            <option value="PatientName" selected="@(Context.Request.Query["searchBy"] == "PatientName")">
                Patient Name
            </option>

            <option value="DoctorName" selected="@(Context.Request.Query["searchBy"] == "DoctorName")">
                Doctor Name
            </option>

            <option value="BillDate" selected="@(Context.Request.Query["searchBy"] == "BillDate")">
                Bill Date
            </option>

            <option value="AppointmentDate" selected="@(Context.Request.Query["searchBy"] == "AppointmentDate")">
                Appointment Date
            </option>

        </select>

        <input type="text"
               name="searchString"
               value="@Context.Request.Query["searchString"]"
               placeholder="Search bills..." />

        <select name="sortBy">

            <option value="PatientName" selected="@(Context.Request.Query["sortBy"] == "PatientName")">
                Patient Name
            </option>

            <option value="DoctorName" selected="@(Context.Request.Query["sortBy"] == "DoctorName")">
                Doctor Name
            </option>

            <option value="BillDate" selected="@(Context.Request.Query["sortBy"] == "BillDate")">
                Bill Date
            </option>

            <option value="AppointmentDate" selected="@(Context.Request.Query["sortBy"] == "AppointmentDate")">
                Appointment Date
            </option>

            <option value="TotalAmount" selected="@(Context.Request.Query["sortBy"] == "TotalAmount")">
                Total Amount
            </option>

        </select>

        <select name="sortOrder">

            <option value="asc" selected="@(Context.Request.Query["sortOrder"] == "asc")">
                Ascending
            </option>

            <option value="desc" selected="@(Context.Request.Query["sortOrder"] == "desc")">
                Descending
            </option>

        </select>

        <button type="submit" class="btn-search">
            Search
        </button>

        <a asp-action="Index" class="btn-cancel">
            Reset
        </a>

    </form>

    @if (TempData["Success"] != null)
    {
        <div class="alert-success">
            @TempData["Success"]
        </div>
    }

    <!-- Table -->
    <div class="table-container">

        <table class="table">

            <thead>
                <tr>
                    <th>Bill ID</th>
                    <th>Patient</th>
                    <th>Doctor</th>
                    <th>Consultation Fee</th>
                    <th>Additional Charges</th>
                    <th>Discount</th>
                    <th>Total Amount</th>
                    <th>Payment Status</th>
                    <th>Bill Date</th>
                    <th>Info</th>
                </tr>
            </thead>

            <tbody>

                @if (Model.Items.Any())
                {
                    @foreach (var bill in Model.Items)
                    {
                        <tr>

                            <td>@bill.Id</td>

                            <td>@bill.PatientName</td>

                            <td>@bill.DoctorName</td>

                            <td>
                                ₹@bill.ConsultationFee.ToString("N2")
                            </td>

                            <td>
                                ₹@bill.AdditionalCharges.ToString("N2")
                            </td>

                            <td>
                                ₹@bill.Discount.ToString("N2")
                            </td>

                            <td>
                                <strong>₹@bill.TotalAmount.ToString("N2")</strong>
                            </td>

                            <td>
                                @bill.PaymentStatus
                            </td>

                            <td>
                                @bill.BillDate.ToString("dd MMM yyyy")
                            </td>

                            <td>

                                <a asp-action="Details"
                                   asp-route-id="@bill.Id"
                                   class="btn-info">
                                    Details
                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@bill.Id"
                                   class="btn-edit">
                                    Edit
                                </a>

                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="10" class="text-center">
                            No bills found.
                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

    <!-- Pagination -->
    <div class="pagination">

        @if (Model.PageNumber > 1)
        {
            <a asp-action="Index"
               asp-route-pageNumber="@(Model.PageNumber - 1)"
               asp-route-pageSize="@Model.PageSize"
               asp-route-searchBy="@Context.Request.Query["searchBy"]"
               asp-route-searchString="@Context.Request.Query["searchString"]"
               asp-route-sortBy="@Context.Request.Query["sortBy"]"
               asp-route-sortOrder="@Context.Request.Query["sortOrder"]"
               class="page-btn">
                Prev
            </a>
        }

        <span class="page-info">
            Page @Model.PageNumber of @Model.TotalPages
        </span>

        @if (Model.PageNumber < Model.TotalPages)
        {
            <a asp-action="Index"
               asp-route-pageNumber="@(Model.PageNumber + 1)"
               asp-route-pageSize="@Model.PageSize"
               asp-route-searchBy="@Context.Request.Query["searchBy"]"
               asp-route-searchString="@Context.Request.Query["searchString"]"
               asp-route-sortBy="@Context.Request.Query["sortBy"]"
               asp-route-sortOrder="@Context.Request.Query["sortOrder"]"
               class="page-btn">
                Next
            </a>
        }

    </div>

</div>
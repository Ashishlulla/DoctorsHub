@model PagedResult<PatientDto>

@{
    ViewData["Title"] = "Patients";
}

<div class="page-container">

    <!-- Header -->
    <div class="header">
        <h2>Patients</h2>

        <div class="actions">
            <a asp-action="Create" class="btn-save">
                + Add Patient
            </a>
        </div>
    </div>

    <!-- Search + Filter -->
    <form method="get" class="filter-bar">

        <!-- Search By -->
        <select name="searchBy">
            <option value="FullName" selected="@(Context.Request.Query["searchBy"] == "FullName")">Full Name</option>
            <option value="Email" selected="@(Context.Request.Query["searchBy"] == "Email")">Email</option>
            <option value="PhoneNumber" selected="@(Context.Request.Query["searchBy"] == "PhoneNumber")">Phone Number</option>
            <option value="BloodGroup" selected="@(Context.Request.Query["searchBy"] == "BloodGroup")">Blood Group</option>
        </select>

        <!-- Search Text -->
        <input type="text"
               name="searchString"
               value="@Context.Request.Query["searchString"]"
               placeholder="Search patient..." />

        <!-- Sort By -->
        <select name="sortBy">
            <option value="FullName" selected="@(Context.Request.Query["sortBy"] == "FullName")">Name</option>
            <option value="DateOfBirth" selected="@(Context.Request.Query["sortBy"] == "DateOfBirth")">Date of Birth</option>
            <option value="BloodGroup" selected="@(Context.Request.Query["sortBy"] == "BloodGroup")">Blood Group</option>
        </select>

        <!-- Sort Order -->
        <select name="sortOrder">
            <option value="asc" selected="@(Context.Request.Query["sortOrder"] == "asc")">Ascending</option>
            <option value="desc" selected="@(Context.Request.Query["sortOrder"] == "desc")">Descending</option>
        </select>

        <button type="submit" class="btn-search">
            Search
        </button>

        <a asp-action="Index" class="btn-cancel">
            Reset
        </a>

    </form>

    @if (TempData["Success"] != null)
    {
        <div class="alert-success">
            @TempData["Success"]
        </div>
    }

    <!-- Table -->
    <div class="table-container">

        <table class="table">

            <thead>
                <tr>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Phone Number</th>
                    <th>Date of Birth</th>
                    <th>Gender</th>
                    <th>Blood Group</th>
                    <th>Info</th>
                </tr>
            </thead>

            <tbody>

                @if (Model.Items.Any())
                {
                    @foreach (var patient in Model.Items)
                    {
                        <tr>
                            <td>@patient.FullName</td>
                            <td>@patient.Email</td>
                            <td>@patient.PhoneNumber</td>
                            <td>@patient.DateOfBirth.ToString("dd-MMM-yyyy")</td>
                            <td>@patient.Gender</td>
                            <td>@patient.BloodGroup</td>

                            <td>
                                <a asp-action="Details"
                                   asp-route-id="@patient.Id"
                                   class="btn-info">
                                    Details
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center">
                            No patients found.
                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

    <!-- Pagination -->
    <div class="pagination">

        @if (Model.PageNumber > 1)
        {
            <a asp-action="Index"
               asp-route-PageNumber="@(Model.PageNumber - 1)"
               asp-route-searchBy="@Context.Request.Query["searchBy"]"
               asp-route-searchString="@Context.Request.Query["searchString"]"
               asp-route-Gender="@Context.Request.Query["Gender"]"
               asp-route-BloodGroup="@Context.Request.Query["BloodGroup"]"
               asp-route-sortBy="@Context.Request.Query["sortBy"]"
               asp-route-sortOrder="@Context.Request.Query["sortOrder"]"
               class="page-btn">
                Prev
            </a>
        }

        <span class="page-info">
            Page @Model.PageNumber of @Model.TotalPages
        </span>

        @if (Model.PageNumber < Model.TotalPages)
        {
            <a asp-action="Index"
               asp-route-PageNumber="@(Model.PageNumber + 1)"
               asp-route-searchBy="@Context.Request.Query["searchBy"]"
               asp-route-searchString="@Context.Request.Query["searchString"]"
               asp-route-Gender="@Context.Request.Query["Gender"]"
               asp-route-BloodGroup="@Context.Request.Query["BloodGroup"]"
               asp-route-sortBy="@Context.Request.Query["sortBy"]"
               asp-route-sortOrder="@Context.Request.Query["sortOrder"]"
               class="page-btn">
                Next
            </a>
        }

    </div>

</div>
@model UpdatePatientDto

@{
    ViewData["Title"] = "Edit Patient";
}

<link rel="stylesheet" href="~/css/createPage.css" asp-append-version="true" />


<div class="create-page">


    <!-- ===== HEADER ===== -->

    <div class="create-header">


        <h2>
            Edit Patient
        </h2>



        <div class="create-actions">


            <button type="submit"
                    form="patientEditForm"
                    class="create-btn-save">

                Update

            </button>



            <a asp-action="Index"
               class="create-btn-cancel">

                Cancel

            </a>


        </div>


    </div>





    <!-- ===== FORM ===== -->


    <form id="patientEditForm"
          asp-action="Edit"
          method="post">


        <input asp-for="Id"
               type="hidden" />



        <div class="create-card">





            <!-- ================= Personal Information ================= -->


            <section class="create-section">


                <h3>
                    Personal Information
                </h3>


                <hr />



                <div class="create-form-group">



                    <div>

                        <label asp-for="FullName"
                               class="create-label">
                        </label>


                        <input asp-for="FullName"
                               class="create-input" />


                        <span asp-validation-for="FullName"
                              class="text-danger">
                        </span>


                    </div>





                    <div>

                        <label asp-for="Email"
                               class="create-label">
                        </label>


                        <input asp-for="Email"
                               class="create-input" />


                        <span asp-validation-for="Email"
                              class="text-danger">
                        </span>


                    </div>





                    <div>

                        <label asp-for="DateOfBirth"
                               class="create-label">
                        </label>


                        <input asp-for="DateOfBirth"
                               type="date"
                               class="create-input" />


                        <span asp-validation-for="DateOfBirth"
                              class="text-danger">
                        </span>


                    </div>





                    <div>

                        <label asp-for="Gender"
                               class="create-label">
                        </label>



                        <select asp-for="Gender"
                                class="create-input">


                            <option value="Male">
                                Male
                            </option>


                            <option value="Female">
                                Female
                            </option>


                            <option value="Other">
                                Other
                            </option>


                        </select>



                        <span asp-validation-for="Gender"
                              class="text-danger">
                        </span>


                    </div>



                </div>


            </section>









            <!-- ================= Contact Information ================= -->


            <section class="create-section">


                <h3>
                    Contact Information
                </h3>


                <hr />



                <div class="create-form-group">



                    <div>

                        <label asp-for="PhoneNumber"
                               class="create-label">
                        </label>


                        <input asp-for="PhoneNumber"
                               class="create-input" />


                        <span asp-validation-for="PhoneNumber"
                              class="text-danger">
                        </span>


                    </div>





                    <div>

                        <label asp-for="BloodGroup"
                               class="create-label">
                        </label>



                        <select asp-for="BloodGroup"
                                class="create-input">


                            <option value="A+">
                                A+
                            </option>


                            <option value="A-">
                                A-
                            </option>


                            <option value="B+">
                                B+
                            </option>


                            <option value="B-">
                                B-
                            </option>


                            <option value="AB+">
                                AB+
                            </option>


                            <option value="AB-">
                                AB-
                            </option>


                            <option value="O+">
                                O+
                            </option>


                            <option value="O-">
                                O-
                            </option>


                        </select>



                        <span asp-validation-for="BloodGroup"
                              class="text-danger">
                        </span>


                    </div>



                </div>


            </section>









            <!-- ================= Address ================= -->


            <section class="create-section">


                <h3>
                    Address
                </h3>


                <hr />



                <div class="create-form-group">



                    <div class="full-width">


                        <label asp-for="Address"
                               class="create-label">
                        </label>



                        <textarea asp-for="Address"
                                  class="create-textarea"
                                  rows="5">
                        </textarea>



                        <span asp-validation-for="Address"
                              class="text-danger">
                        </span>


                    </div>



                </div>


            </section>







            <!-- Delete -->

            <div class="delete-actions">


                <a asp-action="Delete"
                   asp-route-id="@Model.Id"
                   class="btn-delete">

                    Delete

                </a>


            </div>





        </div>


    </form>



</div>



@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}
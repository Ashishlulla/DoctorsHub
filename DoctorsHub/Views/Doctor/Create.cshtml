@model CreateDoctorDto

<div class="page-container">

    <!-- ===== HEADER ===== -->
    <div class="header">
        <h2>Create Doctor</h2>

        <div class="actions">
            <button type="submit" form="doctorForm" class="btn-save">Save</button>
            <button type="button" class="btn-cancel" onclick="window.history.back()">Cancel</button>
        </div>
    </div>

    <!-- ===== FORM CARD ===== -->
    <form id="doctorForm" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-card">

            <!-- ================= Account Information ================= -->
            <section class="form-section">
                <h3>Account Information</h3>
                <hr />

                <div class="form-group">

                    <div>
                        <label>Full Name</label>
                        <input type="text"
                               name="FullName"
                               placeholder="Enter full name"
                               required />
                    </div>

                    <div>
                        <label>Email</label>
                        <input type="email"
                               name="Email"
                               placeholder="doctor@email.com"
                               required />
                    </div>

                    <div>
                        <label>Password</label>
                        <input type="password"
                               name="Password"
                               placeholder="enter password"
                               required />
                    </div>

                    <div>
                        <label>Consultation Fee (₹)</label>
                        <input type="number"
                               name="ConsultationFee"
                               placeholder="e.g. 500" />
                    </div>

                </div>
            </section>

            <!-- ================= Professional Information ================= -->
            <section class="form-section">
                <h3>Professional Information</h3>
                <hr />

                <div class="form-group">

                    <div>
                        <label>Qualification</label>
                        <input type="text"
                               name="Qualification"
                               placeholder="MBBS, MD..." />
                    </div>

                    <div>
                        <label>Specialization</label>

                        <select asp-for="SpecializationId" asp-items="ViewBag.Specializations">
                            <option value="">-- Select Specialization --</option>
                        </select>

                        <span asp-validation-for="SpecializationId"
                              class="text-danger"></span>
                    </div>

                    <div>
                        <label>Experience (Years)</label>
                        <input type="number"
                               name="ExperienceYears"
                               placeholder="e.g. 5" />
                    </div>

                    <div>
                        <label>Visit Days</label>
                        <input type="text"
                               name="VisitDays"
                               placeholder="Mon - Fri" />
                    </div>

                </div>
            </section>

            <!-- ================= Practice Information ================= -->
            <section class="form-section">
                <h3>Practice Information</h3>
                <hr />

                <div class="form-group">

                    

                    <div class="full-width">
                        <label>About</label>
                        <textarea name="About"
                                  rows="4"
                                  placeholder="Write a short professional description..."></textarea>
                    </div>

                </div>
            </section>

        </div>

    </form>

</div>


@model DoctorDto

@{
    ViewBag.Title = "Doctor Details";
}

<div class="page-container">

    <!-- ===== HEADER ===== -->
    <div class="header">
        <h2>Doctor Details</h2>

        <div class="actions">
            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn-save">
                Edit
            </a>

            <a asp-action="Index"
               class="btn-cancel">
                Back
            </a>
        </div>

        

    </div>

    <!-- ===== CARD ===== -->
    <div class="form-card">
        <div class="doctor-profile">

            <div class="doctor-avatar">
                @Model.FullName.Substring(0, 1)
            </div>

            <div class="doctor-info">
                <h3>@Model.FullName</h3>

                <p class="specialization">
                    @Model.SpecializationName
                </p>

                <p class="rating">
                    @if (Model.AverageRating > 0)
                    {
                        <span>⭐ @Model.AverageRating.ToString("F1")</span>
                    }
                    else
                    {
                        <span>No Ratings</span>
                    }
                </p>
            </div>

        </div>

        <!-- ===== GRID DETAILS ===== -->
        <div class="details-grid">

            <div class="detail-item">
                <span class="label">Full Name</span>
                <span class="value">@Model.FullName</span>
            </div>

            <div class="detail-item">
                <span class="label">Email</span>
                <span class="value">
                    @(string.IsNullOrWhiteSpace(Model.User.Email) ? "N/A" : Model.User.Email)
                </span>
            </div>
            <div class="detail-item">
                <span class="label">Contact Number</span>
                <span class="value">
                    @(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "N/A" : Model.PhoneNumber)
                </span>
            </div>

            <div class="detail-item">
                <span class="label">Qualification</span>
                <span class="value">@Model.Qualification</span>
            </div>

            <div class="detail-item">
                <span class="label">Specialization</span>
                <span class="value">@Model.SpecializationName</span>
            </div>

            <div class="detail-item">
                <span class="label">Experience</span>
                <span class="value">@Model.ExperienceYears Years</span>
            </div>

            <div class="detail-item">
                <span class="label">Consultation Fee</span>
                <span class="value">₹@Model.ConsultationFee.ToString("N2")</span>
            </div>

            <div class="detail-item">
                <span class="label">Visit Days</span>
                <span class="value">@Model.VisitDays</span>
            </div>

            <div class="detail-item">
                <span class="label">About</span>
                <span class="value">@Model.About</span>
            </div>

           

           

            @* <div class="detail-item">
                <span class="label">Created</span>
                <span class="value">@Model.CreatedAt.ToString("dd MMM yyyy")</span>
            </div>

            <div class="detail-item">
                <span class="label">Last Updated</span>
                <span class="value">@Model.UpdatedAt.ToString("dd MMM yyyy")</span>
            </div> *@

        </div>

    </div>

</div>
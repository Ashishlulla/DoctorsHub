@model UpdateAppointmentDto

@using Microsoft.AspNetCore.Mvc.Rendering

<div class="page-container">

    <!-- ===== HEADER ===== -->
    <div class="header">
        <h2>Edit Appointment</h2>

        <div class="actions">
            <button type="submit"
                    form="appointmentForm"
                    class="btn-save">
                Update
            </button>

            <button type="button"
                    class="btn-cancel"
                    onclick="window.history.back()">
                Cancel
            </button>
        </div>
    </div>

    <!-- ===== FORM ===== -->
    <form id="appointmentForm" method="post">

        <input asp-for="Id" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-card">

            <!-- ================= Appointment Details ================= -->
            <section class="form-section">

                <h3>Appointment Details</h3>
                <hr />

                <div class="form-group">

                    <div>
                        <label asp-for="PatientId"></label>

                        <select asp-for="PatientId"
                                asp-items="@(new SelectList(ViewBag.Patients, "Id", "FullName"))">
                            <option value="">-- Select Patient --</option>
                        </select>

                        <span asp-validation-for="PatientId" class="text-danger"></span>
                    </div>

                    <div>
                        <label asp-for="DoctorId"></label>

                        <select asp-for="DoctorId"
                                asp-items="@(new SelectList(ViewBag.Doctors, "Id", "FullName"))">
                            <option value="">-- Select Doctor --</option>
                        </select>

                        <span asp-validation-for="DoctorId" class="text-danger"></span>
                    </div>

                    <div>
                        <label asp-for="AppointmentDate"></label>

                        <input asp-for="AppointmentDate"
                               type="date" />

                        <span asp-validation-for="AppointmentDate"
                              class="text-danger"></span>
                    </div>

                </div>

            </section>

            <!-- ================= Appointment Timing ================= -->
            <section class="form-section">

                <h3>Appointment Timing</h3>
                <hr />

                <div class="form-group">

                    <div>
                        <label asp-for="StartTime"></label>

                        <input asp-for="StartTime"
                               type="time" />

                        <span asp-validation-for="StartTime"
                              class="text-danger"></span>
                    </div>

                    <div>
                        <label asp-for="EndTime"></label>

                        <input asp-for="EndTime"
                               type="time" />

                        <span asp-validation-for="EndTime"
                              class="text-danger"></span>
                    </div>

                </div>

            </section>

            <!-- ================= Reason ================= -->
            <section class="form-section">

                <h3>Reason for Visit</h3>
                <hr />

                <div class="form-group">

                    <div class="full-width">

                        <label asp-for="Reason"></label>

                        <textarea asp-for="Reason"
                                  rows="3"
                                  placeholder="Enter appointment reason"></textarea>

                        <span asp-validation-for="Reason"
                              class="text-danger"></span>

                    </div>

                </div>

            </section>

            <!-- ================= Notes ================= -->
            <section class="form-section">

                <h3>Additional Notes</h3>
                <hr />

                <div class="form-group">

                    <div class="full-width">

                        <label asp-for="Notes"></label>

                        <textarea asp-for="Notes"
                                  rows="4"
                                  placeholder="Additional notes"></textarea>

                        <span asp-validation-for="Notes"
                              class="text-danger"></span>

                    </div>

                </div>

            </section>
            <hr />

            <div class="delete-actions">

                <a asp-action="Delete"
                   asp-route-id="@Model.Id"
                   class="btn-delete">
                    Delete 
                </a>

            </div>

        </div>

    </form>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}